{
  "name": "url-shortener-backend",
  "version": "1.0.0",
  "description": "Production-grade URL Shortener Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate": "ts-node migrations/run.ts",
    "seed": "node dist/migrations/seed.js"
  },
  "dependencies": {
    "amqplib": "^0.10.0",
    "bcryptjs": "^2.4.0",
    "cors": "^2.8.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^6.0.0",
    "helmet": "^7.0.0",
    "joi": "^17.0.0",
    "jsonwebtoken": "^9.0.0",
    "nanoid": "^4.0.0",
    "node-cache": "^5.0.0",
    "pg": "^8.0.0",
    "rate-limit-redis": "^4.0.0",
    "redis": "^4.0.0",
    "typescript": "^5.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.0.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.19.42",
    "@types/pg": "^8.20.0",
    "@types/redis": "^4.0.10",
    "@types/supertest": "^2.0.0",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "nodemon": "^3.0.0",
    "prettier": "^3.0.0",
    "supertest": "^6.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0"
  }
}
